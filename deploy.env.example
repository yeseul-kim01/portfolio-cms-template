# 배포 설정. 복사해서 deploy.env 로 쓰세요 (deploy.env 는 .gitignore 됨):  cp deploy.env.example deploy.env
# scripts/deploy-frontend.sh, deploy-backend.sh 가 읽습니다.

AWS_PROFILE=default
REGION=ap-northeast-2
STACK_NAME=portfolio-cms          # samconfig.toml 의 stack_name 과 동일

# 아래 3개는 비워두면 백엔드 스택(CloudFormation) Outputs 에서 자동으로 읽어옵니다.
# (백엔드를 먼저 배포하면 끝 — 프론트 S3/CloudFront 도 스택이 같이 만들어요)
API_URL=
BUCKET=
DIST_ID=

# 빌드에 박히는 신원·소셜
SITE_NAME=Your Name
SITE_BRAND=PF                    # 상단바 로고 텍스트
SITE_EMAIL=you@example.com
SITE_DOMAIN=yourdomain.com
BLOG_URL=https://yourblog.tistory.com
GITHUB_URL=https://github.com/your-id
HF_URL=
HERO_IMAGE=                      # 홈 중앙 이미지(public 경로). 비우면 숨김
FAVICON=                         # 브라우저 탭 아이콘(public 경로). 비우면 기본 /logo.svg

# 프론트엔드 환경변수 (Vite). 복사해서 .env 로 쓰세요:  cp .env.example .env
# 로컬 개발은 보통 아래 한 줄이면 됩니다. (백엔드 localhost:8080 또는 운영 ApiUrl)
VITE_API_BASE_URL=http://localhost:8080

# (선택) 신원·소셜 — 비우면 src/config/site.ts 의 기본값 사용
# VITE_SITE_NAME=Your Name
# VITE_SITE_BRAND=PF                 # 상단바 로고 텍스트(이니셜 등)
# VITE_SITE_ROLE=Backend · AI · Infrastructure Engineer
# VITE_SITE_EMAIL=you@example.com
# VITE_SITE_DOMAIN=yourdomain.com
# VITE_BLOG_URL=https://yourblog.tistory.com
# VITE_GITHUB_URL=https://github.com/your-id
# VITE_HF_URL=
# VITE_HERO_IMAGE=/your-logo.png     # 홈 중앙 이미지(public 경로). 비우면 숨김
# VITE_FAVICON=/your-favicon.svg     # 브라우저 탭 아이콘. 비우면 기본 /logo.svg
